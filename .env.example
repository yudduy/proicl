# Copy to .env for local runs. Never commit real values.

# Required only for GPQA-Diamond official rows, gated HF models, or private Hub access.
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=
GPQA_DIAMOND_PATH=

# Required only for live xAI/OpenAI-compatible GEPA reflection calls.
XAI_API_KEY=

# Optional API-backed comparators / vendored baselines.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
SAMBANOVA_API_KEY=
COMMONSTACK_API_KEY=

# Optional local dataset fixture overrides.
MATH_OPTIMIZER_DEV_PATH=
CODE_OPTIMIZER_DEV_PATH=
GPQA_NON_DIAMOND_PATH=
HUMANEVAL_OVERRIDE_PATH=
REASONING_GYM_FIXTURE_PATH=

# Optional runtime paths.
HF_HOME=
HF_HUB_CACHE=
TRANSFORMERS_CACHE=
CUDA_VISIBLE_DEVICES=
